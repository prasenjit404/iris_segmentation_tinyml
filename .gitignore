# ======================================
# Project outputs (generated)
# ======================================
outputs/**
!outputs/.gitkeep

# Auto-generated upload cache from Streamlit inference
outputs/inference_uploads/**

# ======================================
# Models and data artifacts
# ======================================
# Keep these scoped to generated output locations to avoid
# accidentally ignoring real source files with the same extensions.
outputs/**/*.npz
outputs/**/*.npy
outputs/**/*.h
outputs/**/*.pkl
outputs/**/*.pickle
outputs/**/*.joblib
outputs/**/*.onnx
outputs/**/*.tflite

